// ============================================
// LevelUp — Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String?
  avatar           String?
  googleId         String?   @unique
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isOnboarded      Boolean   @default(false)
  jobTitle         String?
  dreamRole        String?
  targetIncome     Decimal?
  primaryFocus     String?   // fitness, finance, career
  baseCurrency     Currency  @default(INR)
  monthlyBudget    Decimal?
  codingLanguage   String?   // python, cpp, java, javascript
  githubUrl        String?
  portfolioUrl     String?
  gender           String?   // male, female, other
  dateOfBirth      DateTime?

  // ── Identity Expansion ──
  currentSalary    Decimal?
  phoneNumber      String?
  address          String?
  city             String?
  country          String?
  timezone         String?   @default("UTC")
  mantra           String?
  theme            String?   @default("system")
  onboardingStep   Int?      @default(1)
  leetcodeUrl      String?
  linkedinUrl      String?
  twitterUrl       String?
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  rankTitle        String    @default("Novice")
  notificationPrefs Json?

  totalXp         Int      @default(0)
  level            Int      @default(1)
  activeDsaPathId  String?

  refreshTokens     RefreshToken[]
  habits            Habit[]
  habitLogs         HabitLog[]
  goals             Goal[]
  reflections       Reflection[]
  dsaProgress       DsaUserProgress[]
  dsaRevisionLogs   DsaRevisionLog[]
  dsaPatternMastery DsaPatternMastery[]
  dsaTopicMastery   DsaTopicMastery[]
  dsaPathProgress   DsaPathProgress[]
  dsaUnlockedPaths  DsaUnlockedPath[]
  dsaHeatmap        DsaHeatmap[]
  jobApplications    JobApplication[]
  projects           Project[]
  githubConnection   GithubConnection?
  transactions       Transaction[]
  focusSessions      FocusSession[]

  // ── Fitness relations ──
  fitnessProfile     FitnessProfile?
  workoutPlans       WorkoutPlan[]
  workoutSessions    WorkoutSession[]
  workoutMemories    WorkoutMemory[]
  mealLogs           MealLog[]
  waterLogs          WaterLog[]
  bodyMetrics        BodyMetric[]
  bodyMeasurements   BodyMeasurement[]
  progressPhotos     ProgressPhoto[]
  fitnessMilestones  FitnessMilestone[]
  fitnessInsights    FitnessInsight[]
  dietPlans          DietPlan[]
  recoveryPlans      RecoveryPlan[]
  planGenerationLogs PlanGenerationLog[]
  adherenceScores    AdherenceScore[]
  sleepLogs          SleepLog[]
  recoveryLogs       RecoveryLog[]

  // ── Finance relations ──
  financeAccounts        FinanceAccount[]
  financeCategories      FinanceCategory[]
  budgets                Budget[]
  financeGoals           FinanceGoal[]
  subscriptions          Subscription[]
  debts                  Debt[]
  insurances             Insurance[]
  bills                  Bill[]
  moneyStreaks           MoneyStreak[]
  monthlyReflections     MonthlyReflection[]
  aiFinanceInsights      AIFinanceInsight[]
  weeklyFinanceChallenges WeeklyFinanceChallenge[]

  // ── Analytics relations ──
  analyticsSnapshots     AnalyticsSnapshot[]
  aiAnalyticsInsights    AIAnalyticsInsight[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==================== HABITS ====================

model Habit {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  icon         String    @default("check-circle")
  color        String    @default("#6366f1")
  category     String    @default("general")
  frequency    Frequency @default(DAILY)
  reminderTime String?
  isArchived   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  logs HabitLog[]

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id          String   @id @default(cuid())
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime @db.Date
  note        String?
  createdAt   DateTime @default(now())

  @@unique([habitId, completedAt])
  @@index([habitId])
  @@index([userId])
  @@index([completedAt])
  @@map("habit_logs")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ==================== GOALS ====================

model Goal {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        GoalType
  status      GoalStatus @default(IN_PROGRESS)
  progress    Int          @default(0)
  category    GoalCategory @default(PERSONAL)
  startDate   DateTime     @db.Date
  endDate     DateTime     @db.Date
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  milestones GoalMilestone[]

  @@index([userId])
  @@index([type])
  @@map("goals")
}

model GoalMilestone {
  id          String    @id @default(cuid())
  goalId      String
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([goalId])
  @@map("goal_milestones")
}

enum GoalType {
  WEEKLY
  MONTHLY
}

enum GoalCategory {
  HEALTH
  FITNESS
  LEARNING
  CAREER
  PERSONAL
}

enum GoalStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ==================== REFLECTIONS ====================

model Reflection {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ReflectionType
  title        String?
  content      String
  mood         Int?
  tags         String[]       @default([])
  gratitude    String?
  improvements String?
  date         DateTime       @db.Date
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([date])
  @@map("reflections")
}

enum ReflectionType {
  DAILY
  WEEKLY
  MONTHLY
}

// ==================== DSA TRACKER V2 ====================

model DsaPath {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  fileName      String   @unique
  source        String
  icon          String   @default("route")
  difficulty    String   @default("Mixed")
  totalProblems Int      @default(0)
  tier          Int      @default(1)
  createdAt     DateTime @default(now())

  pathProblems  DsaPathProblem[]
  pathProgress  DsaPathProgress[]
  unlockedBy    DsaUnlockedPath[]

  @@map("dsa_paths")
}

model DsaProblem {
  id                 String   @id @default(cuid())
  externalId         String
  title              String
  slug               String
  difficulty         String
  url                String
  canonicalProblemId String
  platform           String   @default("LeetCode")
  source             String
  estimatedTime      Int      @default(20)
  revisionWeight     Int      @default(1)
  companies          String[] @default([])
  tags               String[] @default([])
  patterns           String[] @default([])
  prerequisites      String[] @default([])
  leetcodeUrl        String   @default("")
  isPremium          Boolean  @default(false)
  createdAt          DateTime @default(now())

  pathProblems  DsaPathProblem[]
  userProgress  DsaUserProgress[]
  revisionLogs  DsaRevisionLog[]

  @@unique([canonicalProblemId, platform])
  @@index([canonicalProblemId])
  @@index([leetcodeUrl])
  @@index([difficulty])
  @@map("dsa_problems")
}

model DsaPathProblem {
  id         String     @id @default(cuid())
  pathId     String
  path       DsaPath    @relation(fields: [pathId], references: [id], onDelete: Cascade)
  problemId  String
  problem    DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  topic      String
  subtopic   String?
  orderIndex Int

  @@unique([pathId, problemId])
  @@index([pathId])
  @@index([problemId])
  @@index([topic])
  @@map("dsa_path_problems")
}

model DsaUserProgress {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId    String
  problem      DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  status       DsaStatus @default(TODO)
  attemptCount Int       @default(0)
  solvedAt     DateTime?
  confidence   Int       @default(0)
  revisionDue  DateTime?
  notes        String?
  timeSpent    Int?
  xpEarned     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([revisionDue])
  @@map("dsa_user_progress")
}

model DsaRevisionLog {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId     String
  problem       DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  revisionDate  DateTime   @default(now())
  revisionCount Int        @default(1)
  performance   String     @default("good")
  createdAt     DateTime   @default(now())

  @@index([userId])
  @@index([problemId])
  @@index([revisionDate])
  @@map("dsa_revision_logs")
}

model DsaPatternMastery {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern     String
  solvedCount Int      @default(0)
  totalCount  Int      @default(0)
  masteryPct  Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, pattern])
  @@index([userId])
  @@map("dsa_pattern_mastery")
}

model DsaTopicMastery {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       String
  solvedCount Int      @default(0)
  totalCount  Int      @default(0)
  masteryPct  Int      @default(0)
  weakScore   Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, topic])
  @@index([userId])
  @@map("dsa_topic_mastery")
}

model DsaPathProgress {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathId        String
  path          DsaPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  solvedCount   Int     @default(0)
  xpEarned      Int     @default(0)
  completionPct Int     @default(0)

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("dsa_path_progress")
}

model DsaUnlockedPath {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathId    String
  path      DsaPath  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([userId, pathId])
  @@index([userId])
  @@map("dsa_unlocked_paths")
}

model DsaHeatmap {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  count    Int      @default(0)
  xpEarned Int      @default(0)

  @@unique([userId, date])
  @@index([userId])
  @@map("dsa_heatmap")
}

model CompanyDsaMap {
  id       String   @id @default(cuid())
  company  String
  topics   String[] @default([])
  patterns String[] @default([])
  priority Int      @default(0)

  @@index([company])
  @@map("company_dsa_maps")
}

enum DsaStatus {
  TODO
  IN_PROGRESS
  SOLVED
  REVISING
}

// ==================== JOB TRACKER ====================

model JobApplication {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  role         String
  location     String?
  type         JobType   @default(FULL_TIME)
  status       JobStatus @default(SAVED)
  url          String?
  salary       String?
  notes        String?
  appliedDate  DateTime?
  deadline     DateTime?
  contactName  String?
  contactEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  source              String?
  requiredSkills      String[]  @default([])
  experience          String?
  workMode            String?
  description         String?
  companyInfo         String?
  interviewRounds     Json?
  matchScore          Int?
  recruiterNotes      String?
  interviewNotes      String?
  companyResearch     String?
  checklist           Json?
  personalNotes       String?
  aiPrepData          Json?
  aiPrepStatus        String    @default("idle")
  aiPrepLastGeneratedAt DateTime?
  prepStarted         Boolean   @default(false)
  prepStartedAt       DateTime?
  prepProgress        Int       @default(0)
  prepConfidence      Int       @default(0)
  prepDaysTotal       Int       @default(7)
  stageHistory        Json?

  @@index([userId])
  @@index([status])
  @@map("job_applications")
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
}

enum JobStatus {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

// ==================== PROJECT TRACKER V2 ====================

model GithubConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubId     String   @unique
  username     String
  avatar       String?
  email        String?
  accessToken  String          // encrypted before storage
  scope        String?
  connectedAt  DateTime @default(now())
  lastSyncedAt DateTime?

  @@map("github_connections")
}

model Project {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String          @default("Untitled")
  slug          String          @default("untitled")
  description   String?
  status        ProjectStatus   @default(IDEA)
  priority      ProjectPriority @default(MEDIUM)
  repoUrl       String?
  liveUrl       String?
  githubRepoId  String?
  stack         String[]
  deadline      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tasks         ProjectTask[]
  learnings     ProjectLearning[]
  metrics       ProjectMetrics?
  intelligence  ProjectIntelligence?
  jobMatches    JobProjectMatch[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([status])
  @@map("projects")
}

enum ProjectStatus {
  IDEA
  PLANNING
  BUILDING
  TESTING
  SHIPPED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ProjectTask {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  xpReward    Int       @default(10)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@map("project_tasks")
}

model ProjectLearning {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        String   @default("learning")
  tags        String[]
  impactScore Int      @default(5)
  source      String   @default("manual")
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([type])
  @@map("project_learnings")
}

model ProjectMetrics {
  id             String    @id @default(cuid())
  projectId      String    @unique
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commitCount    Int       @default(0)
  prCount        Int       @default(0)
  issueCount     Int       @default(0)
  buildStreak    Int       @default(0)
  lastCommitAt   DateTime?
  velocityScore  Float     @default(0)
  qualityScore   Float     @default(0)
  portfolioScore Float     @default(0)

  @@map("project_metrics")
}

model ProjectIntelligence {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  architectureScore Float    @default(0)
  scalabilityScore  Float    @default(0)
  resumeScore       Float    @default(0)
  interviewScore    Float    @default(0)
  recruiterScore    Float    @default(0)
  missingSkills     String[]
  strengths         String[]
  weaknesses        String[]
  buildSuggestions  Json?
  updatedAt         DateTime @updatedAt

  @@map("project_intelligence")
}

model JobProjectMatch {
  id                      String   @id @default(cuid())
  jobId                   String
  projectId               String
  project                 Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  matchScore              Float    @default(0)
  missingSkills           String[]
  recommendedImprovements String[]
  createdAt               DateTime @default(now())

  @@unique([jobId, projectId])
  @@map("job_project_matches")
}

// ==================== FINANCE MODULE ====================

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum NecessityLevel {
  ESSENTIAL
  COMFORTABLE
  LUXURY
  WASTEFUL
}

enum MoodType {
  NECESSARY
  HAPPY
  REGRET
  NEUTRAL
}

enum FinanceGoalType {
  EMERGENCY
  ASSET
  TRAVEL
  EDUCATION
  INVESTMENT
  OPPORTUNITY
  CUSTOM
}

enum SubscriptionCycle {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum InsuranceStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  LAPSED
}

enum DebtStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum BillStatus {
  UPCOMING
  PAID
  OVERDUE
}

enum Currency {
  INR
  USD
  EUR
  GBP
  JPY
  AUD
  CAD
}

model Transaction {
  id                       String           @id @default(cuid())
  userId                   String
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId                String?
  account                  FinanceAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  type                     TransactionType
  amount                   Decimal          @db.Decimal(12, 2)
  category                 String
  description              String?
  merchant                 String?
  paymentMethod            String?
  necessityLevel           NecessityLevel?
  mood                     MoodType?
  tags                     String[]         @default([])
  note                     String?
  date                     DateTime         @db.Date
  isRecurring              Boolean          @default(false)
  isSubscriptionCandidate  Boolean          @default(false)
  createdAt                DateTime         @default(now())

  @@index([userId])
  @@index([date])
  @@index([type])
  @@index([category])
  @@index([merchant])
  @@map("transactions")
}

model FinanceAccount {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  type            String        // cash, savings, investment, debt
  balance         Decimal       @db.Decimal(12, 2) @default(0)
  institution     String?
  icon            String?
  color           String?
  isDefault       Boolean       @default(false)
  includeInNetWorth Boolean     @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  transactions    Transaction[]

  @@index([userId])
  @@map("finance_accounts")
}

model FinanceCategory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  color     String?
  type      String   // income, expense
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  budgets   Budget[]

  @@unique([userId, name, type])
  @@index([userId])
  @@map("finance_categories")
}

model Budget {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String
  category      FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  monthlyLimit  Decimal         @db.Decimal(12, 2)
  month         String          // YYYY-MM
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([userId, categoryId, month])
  @@index([userId])
  @@map("budgets")
}

model FinanceGoal {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  goalType      FinanceGoalType  @default(CUSTOM)
  targetAmount  Decimal          @db.Decimal(12, 2)
  currentAmount Decimal          @db.Decimal(12, 2) @default(0)
  deadline      DateTime?
  icon          String?
  color         String?
  priority      String           @default("MEDIUM")
  isCompleted   Boolean          @default(false)
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@map("finance_goals")
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant        String
  amount          Decimal            @db.Decimal(12, 2)
  cycle           SubscriptionCycle  @default(MONTHLY)
  nextRenewal     DateTime?
  status          SubscriptionStatus @default(ACTIVE)
  category        String?
  isDetected      Boolean            @default(false)
  lastChargeDate  DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
  @@map("subscriptions")
}

model Debt {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  type           String     // loan, credit_card, emi
  totalAmount    Decimal    @db.Decimal(12, 2)
  paidAmount     Decimal    @db.Decimal(12, 2) @default(0)
  monthlyEmi     Decimal    @db.Decimal(12, 2) @default(0)
  interestRate   Float      @default(0)
  dueDay         Int        @default(1) // day of month
  status         DebtStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId])
  @@map("debts")
}

model Insurance {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String          // health, term, vehicle, accident
  provider     String
  policyNumber String?
  premium      Decimal         @db.Decimal(12, 2)
  cycle        SubscriptionCycle @default(YEARLY)
  expiryDate   DateTime
  status       InsuranceStatus @default(ACTIVE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId])
  @@map("insurances")
}

model Bill {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  amount      Decimal    @db.Decimal(12, 2)
  dueDate     DateTime
  category    String?
  isRecurring Boolean    @default(false)
  cycle       SubscriptionCycle?
  status      BillStatus @default(UPCOMING)
  paidAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@map("bills")
}

model MoneyStreak {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streakType    String   // no_spend, savings, budget, logging
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  lastUpdated   DateTime @default(now())

  @@unique([userId, streakType])
  @@index([userId])
  @@map("money_streaks")
}

model MonthlyReflection {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month                String   // YYYY-MM
  whatWentWell          String?
  unnecessarySpending  String?
  improvementPlan      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@map("monthly_reflections")
}

model AIFinanceInsight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // cfo, leak, savings, growth, weekly_challenge, wealth_plan, risk
  content   Json
  priority  String   @default("medium") // high, medium, low
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@map("ai_finance_insights")
}

model WeeklyFinanceChallenge {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  xpReward    Int       @default(50)
  target      Int       @default(1)
  progress    Int       @default(0)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  weekStart   DateTime
  weekEnd     DateTime
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([weekStart])
  @@map("weekly_finance_challenges")
}

// ==================== FITNESS MODULE ====================

model ExerciseCatalog {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  muscleGroup String   // chest, back, legs, shoulders, arms, core, full_body
  category    String   // compound, isolation, cardio, flexibility, plyometric
  metValue    Float    @default(5.0)
  isCompound  Boolean  @default(false)
  defaultUnit String   @default("kg") // kg, lbs, bodyweight, minutes
  equipmentType           String?   // barbell, dumbbell, machine, cable, bodyweight, bands
  difficulty              String?   @default("intermediate") // beginner, intermediate, advanced
  injuryContraindications String[]  @default([])  // ["lower_back", "shoulder", "knee"]
  alternatives            String[]  @default([])  // ["Incline DB Press", "Machine Chest Press"]
  instructions            String[]  @default([])
  primaryMuscles          String[]  @default([])
  secondaryMuscles        String[]  @default([])
  images                  String[]  @default([])
  createdAt   DateTime @default(now())

  @@index([muscleGroup])
  @@index([category])
  @@map("exercise_catalog")
}

model FitnessProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  height           Float?   // cm
  weight           Float?   // kg
  bodyFat          Float?   // percentage
  goal             String   @default("general") // strength, hypertrophy, cutting, endurance, general
  trainingDays     Int      @default(5)
  splitType        String   @default("push_pull_legs")
  experienceLevel  String   @default("intermediate")
  dietType         String?  // vegan, vegetarian, keto, paleo, standard
  dailyCalorieGoal Int?     @default(2100)
  dailyProteinGoal Int?     @default(150)
  dailyCarbsGoal   Int?     @default(250)
  dailyFatsGoal    Int?     @default(70)
  dailyWaterGoal   Float?   @default(3.0) // liters
  // ── Planner fields ──
  equipmentAvailable String[]   @default(["full_gym"])
  injuryFlags        String[]   @default([])

  budget            Int?       // monthly food budget in INR
  foodStyle         String?    @default("hybrid") // familiar, hybrid, mixed, bodybuilding
  cookingAbility    String?    @default("basic")  // cannot_cook, basic, full
  mealTiming        String[]   @default(["morning", "afternoon", "evening", "night"])
  lifestyle         String?    // student, desk_job, active_job, shift_worker
  foodDislikes      String[]   @default([])
  supplements       String[]   @default([])  // none, whey, creatine
  sleepHours        Float?     @default(7)
  accessibilityMode Boolean?   @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("fitness_profiles")
}

model WorkoutPlan {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String   // "Strength Building Phase"
  phase      String   // strength_building, hypertrophy, cutting, recovery
  weekNumber Int      @default(1)
  totalWeeks Int      @default(8)
  isActive   Boolean  @default(true)
  schedule   Json     // [{day: 'monday', type: 'Push Day', muscleGroups: [...], exercises: [...]}]
  // ── Planner fields ──
  equipmentAvailable  String[]  @default(["full_gym"])
  injuryFlags         String[]  @default([])
  progressionType     String?   @default("linear") // linear, undulating, block
  deloadWeek          Int?      // which week number is deload
  weeklyOverloadRules Json?     // {compoundIncrement: 2.5, isolationIncrement: 1.25}
  fitnessLevel        String?   // beginner, intermediate, advanced
  version             Int       @default(1)
  parentPlanId        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@map("workout_plans")
}

model WorkoutSession {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String        // "Push Day", "HIIT Cardio"
  type           String        // strength, cardio, hiit, yoga, mobility, sports
  muscleGroups   String[]      // ["chest", "shoulders", "triceps"]
  duration       Int           // minutes
  caloriesBurned Int           @default(0)
  totalVolume    Float         @default(0) // total kg lifted
  notes          String?
  date           DateTime
  completedAt    DateTime?
  planDayId      String?       // which plan day this fulfills
  exercises      ExerciseLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@map("workout_sessions")
}

model ExerciseLog {
  id          String         @id @default(cuid())
  sessionId   String
  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name        String         // "Bench Press"
  muscleGroup String         // "chest"
  sets        Json           // [{setNumber: 1, reps: 12, weight: 70, isWarmup: false}]
  totalVolume Float          @default(0)
  bestSet     Json?          // {reps: 8, weight: 80}
  notes       String?
  orderIndex  Int            @default(0)
  createdAt   DateTime       @default(now())

  @@index([sessionId])
  @@map("exercise_logs")
}

model WorkoutMemory {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseName    String
  lastWeight      Float
  lastReps        Int
  lastDate        DateTime
  bestWeight      Float
  bestReps        Int
  bestDate        DateTime
  suggestedWeight Float?
  suggestedReps   Int?
  updatedAt       DateTime @updatedAt

  @@unique([userId, exerciseName])
  @@index([userId])
  @@map("workout_memories")
}

model MealLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealType      String   // breakfast, lunch, pre_workout, dinner, snacks
  foodItems     Json     // [{name, calories, protein, carbs, fats, quantity}]
  totalCalories Int      @default(0)
  totalProtein  Float    @default(0)
  totalCarbs    Float    @default(0)
  totalFats     Float    @default(0)
  totalFiber    Float?   @default(0)
  totalSugar    Float?   @default(0)
  totalSodium   Float?   @default(0)
  date          DateTime
  time          String?  // "8:30 AM"
  notes         String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
  @@index([date])
  @@map("meal_logs")
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float    // liters
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("water_logs")
}

model BodyMetric {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight     Float?   // kg
  bodyFat    Float?   // percentage
  muscleMass Float?   // kg
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
  @@map("body_metrics")
}

model BodyMeasurement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chest     Float?   // cm
  waist     Float?   // cm
  arms      Float?   // cm
  thighs    Float?   // cm
  date      DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("body_measurements")
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicId  String   // Cloudinary public ID
  secureUrl String   // Cloudinary secure URL
  caption   String?
  date      DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("progress_photos")
}

model FitnessMilestone {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String    // "Weight below 75 kg"
  type         String    // weight, lift, body_fat, endurance
  targetValue  Float?
  currentValue Float?
  isAchieved   Boolean   @default(false)
  achievedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@map("fitness_milestones")
}

model FitnessInsight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // overview, nutrition, progress, plan
  content     Json     // {observations: [], weaknesses: [], recommendations: []}
  generatedAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@map("fitness_insights")
}
// ==================== FOCUS SESSIONS ====================

model FocusSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  duration    Int       // planned duration in minutes
  actualMins  Int?      // actual minutes completed
  label       String    @default("Deep Work Session")
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("focus_sessions")
}

// ==================== ANALYTICS ====================

model AnalyticsSnapshot {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotDate     String   // "YYYY-MM-DD" format for clean daily uniqueness
  lifeScore        Float    @default(0)
  mindScore        Float    @default(0)
  bodyScore        Float    @default(0)
  careerScore      Float    @default(0)
  moneyScore       Float    @default(0)
  disciplineScore  Float    @default(0)
  reflectionScore  Float    @default(0)
  consistencyIndex Float    @default(0)
  growthVelocity   Float    @default(0)
  upgradeScore     Float    @default(0)
  momentumScore    Float    @default(0)
  momentumState    String   @default("Stable") // Rising, Stable, Falling
  xpEarned         Int      @default(0)
  tasksCompleted   Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate])
  @@map("analytics_snapshots")
}

model AIAnalyticsInsight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // QUICK_INSIGHTS, PREDICTIONS
  content   Json
  createdAt DateTime @default(now())

  @@index([userId, type])
  @@map("ai_analytics_insights")
}

// ==================== AI MASTER PLANNER ====================

model DietPlan {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal                String   // fat_loss, muscle_gain, recomp, maintenance
  caloriesTarget      Int
  proteinTarget       Int      // grams
  carbTarget          Int      // grams
  fatTarget           Int      // grams
  foodStyle           String   @default("hybrid") // familiar, hybrid, mixed, bodybuilding
  budget              Int?     // monthly INR
  accessibilityMode   Boolean  @default(false)
  mealsJson           Json     // 7-day meal structure
  groceryJson         Json?    // grocery list
  completionLogs      Json?    // {completed[], skipped[], modified[], missed[]}
  mealTrackingEnabled Boolean  @default(true)
  isActive            Boolean  @default(true)
  version             Int      @default(1)
  parentPlanId        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@map("diet_plans")
}

model RecoveryPlan {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sleepTarget      Float    @default(8)   // hours
  hydrationTarget  Float    @default(3.0) // liters
  mobilityPlan     Json?    // [{day, exercises: [{name, duration, targetArea}]}]
  recoveryDays     String[] @default(["sunday"])
  stressManagement Json?    // {techniques: [], dailyMindfulness: 10}
  isActive         Boolean  @default(true)
  version          Int      @default(1)
  parentPlanId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@map("recovery_plans")
}

model FoodCatalog {
  id                String   @id @default(cuid())
  name              String
  normalizedName    String   @unique // Lowercased + cleaned name for exact-match lookups e.g. "chicken biryani"
  slug              String   @unique
  aliases           String[] @default([]) // e.g. ["chapati", "phulka"]
  category          String   // protein, carb, fat, dairy, fruit, mixed-meal, etc.
  mealTypes         String[] @default([]) // e.g. ["breakfast", "lunch"]
  servingUnit       String   @default("g") // piece, bowl, glass, plate
  servingSize       Float    @default(100)
  unitGramMap       Json?    // e.g. {"piece": 50, "bowl": 180}
  
  // Macros
  calories          Float
  protein           Float
  carbs             Float
  fats              Float
  fiber             Float?
  
  // Existing AI/Business Fields
  estimatedPricePerServing Float? // INR per serving
  priceTier         String   @default("medium") // budget, medium, premium
  availabilityScore Int      @default(8) // 1-10
  cookingDifficulty String   @default("basic") // none, basic, full
  dietType          String[] @default(["non_veg"]) // veg, eggetarian, non_veg, vegan
  
  // Source & Trust
  imageUrl          String?
  source            String   @default("levelup_seed") // INDB, USDA, Kaggle, OFF
  isVerified        Boolean  @default(false) // Verified = USDA / INDB / manual
  confidence        Float?
  varianceLow       Float?
  varianceHigh      Float?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
  @@index([category, mealTypes])
  @@index([slug])
  @@index([source])
  @@index([dietType])
  @@map("food_catalog")
}

model FoodAlternative {
  id                    String   @id @default(cuid())
  sourceFoodName        String
  alternativeFoodName   String
  dietaryCompatibility  String[] @default([])
  budgetTier            String   @default("medium")

  @@unique([sourceFoodName, alternativeFoodName])
  @@map("food_alternatives")
}

model PlanGenerationLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType      String   // workout, diet, recovery, transformation
  inputParams   Json
  outputPlan    Json?
  status        String   // success, failed, fallback
  retryCount    Int      @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("plan_generation_logs")
}

model AdherenceScore {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutScore   Float    @default(0)
  mealScore      Float    @default(0)
  sleepScore     Float    @default(0)
  hydrationScore Float    @default(0)
  recoveryScore  Float    @default(0)
  totalScore     Float    @default(0)
  weekStart      DateTime
  weekEnd        DateTime
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("adherence_scores")
}

model SleepLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hoursSlept Float    // actual hours slept
  quality    String?  // good, fair, poor
  bedTime    String?  // "23:00"
  wakeTime   String?  // "07:00"
  date       DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
  @@map("sleep_logs")
}

model RecoveryLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // rest_day, mobility, stretching, meditation
  duration        Int?     // minutes
  exercises       Json?    // [{name, duration, targetArea}]
  recoveryPlanId  String?
  date            DateTime
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
  @@map("recovery_logs")
}

