// ============================================
// LevelUp — Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String?
  avatar           String?
  googleId         String?   @unique
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  totalXp         Int      @default(0)
  level            Int      @default(1)
  activeDsaPathId  String?

  refreshTokens     RefreshToken[]
  habits            Habit[]
  habitLogs         HabitLog[]
  goals             Goal[]
  reflections       Reflection[]
  dsaProgress       DsaUserProgress[]
  dsaRevisionLogs   DsaRevisionLog[]
  dsaPatternMastery DsaPatternMastery[]
  dsaTopicMastery   DsaTopicMastery[]
  dsaPathProgress   DsaPathProgress[]
  dsaUnlockedPaths  DsaUnlockedPath[]
  dsaHeatmap        DsaHeatmap[]
  jobApplications   JobApplication[]
  projects          Project[]
  transactions      Transaction[]
  workouts          Workout[]
  fitnessLogs       FitnessLog[]
  focusSessions     FocusSession[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==================== HABITS ====================

model Habit {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  icon         String    @default("check-circle")
  color        String    @default("#6366f1")
  category     String    @default("general")
  frequency    Frequency @default(DAILY)
  reminderTime String?
  isArchived   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  logs HabitLog[]

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id          String   @id @default(cuid())
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime @db.Date
  note        String?
  createdAt   DateTime @default(now())

  @@unique([habitId, completedAt])
  @@index([habitId])
  @@index([userId])
  @@index([completedAt])
  @@map("habit_logs")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ==================== GOALS ====================

model Goal {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        GoalType
  status      GoalStatus @default(IN_PROGRESS)
  progress    Int          @default(0)
  category    GoalCategory @default(PERSONAL)
  startDate   DateTime     @db.Date
  endDate     DateTime     @db.Date
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  milestones GoalMilestone[]

  @@index([userId])
  @@index([type])
  @@map("goals")
}

model GoalMilestone {
  id          String    @id @default(cuid())
  goalId      String
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([goalId])
  @@map("goal_milestones")
}

enum GoalType {
  WEEKLY
  MONTHLY
}

enum GoalCategory {
  HEALTH
  FITNESS
  LEARNING
  CAREER
  PERSONAL
}

enum GoalStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ==================== REFLECTIONS ====================

model Reflection {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ReflectionType
  title        String?
  content      String
  mood         Int?
  tags         String[]       @default([])
  gratitude    String?
  improvements String?
  date         DateTime       @db.Date
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([date])
  @@map("reflections")
}

enum ReflectionType {
  DAILY
  WEEKLY
  MONTHLY
}

// ==================== DSA TRACKER V2 ====================

model DsaPath {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  fileName      String   @unique
  source        String
  icon          String   @default("route")
  difficulty    String   @default("Mixed")
  totalProblems Int      @default(0)
  tier          Int      @default(1)
  createdAt     DateTime @default(now())

  pathProblems  DsaPathProblem[]
  pathProgress  DsaPathProgress[]
  unlockedBy    DsaUnlockedPath[]

  @@map("dsa_paths")
}

model DsaProblem {
  id                 String   @id @default(cuid())
  externalId         String
  title              String
  slug               String
  difficulty         String
  url                String
  canonicalProblemId String
  platform           String   @default("LeetCode")
  source             String
  estimatedTime      Int      @default(20)
  revisionWeight     Int      @default(1)
  companies          String[] @default([])
  tags               String[] @default([])
  patterns           String[] @default([])
  prerequisites      String[] @default([])
  leetcodeUrl        String   @default("")
  isPremium          Boolean  @default(false)
  createdAt          DateTime @default(now())

  pathProblems  DsaPathProblem[]
  userProgress  DsaUserProgress[]
  revisionLogs  DsaRevisionLog[]

  @@unique([canonicalProblemId, platform])
  @@index([canonicalProblemId])
  @@index([leetcodeUrl])
  @@index([difficulty])
  @@map("dsa_problems")
}

model DsaPathProblem {
  id         String     @id @default(cuid())
  pathId     String
  path       DsaPath    @relation(fields: [pathId], references: [id], onDelete: Cascade)
  problemId  String
  problem    DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  topic      String
  subtopic   String?
  orderIndex Int

  @@unique([pathId, problemId])
  @@index([pathId])
  @@index([problemId])
  @@index([topic])
  @@map("dsa_path_problems")
}

model DsaUserProgress {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId    String
  problem      DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  status       DsaStatus @default(TODO)
  attemptCount Int       @default(0)
  solvedAt     DateTime?
  confidence   Int       @default(0)
  revisionDue  DateTime?
  notes        String?
  timeSpent    Int?
  xpEarned     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([revisionDue])
  @@map("dsa_user_progress")
}

model DsaRevisionLog {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId     String
  problem       DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  revisionDate  DateTime   @default(now())
  revisionCount Int        @default(1)
  performance   String     @default("good")
  createdAt     DateTime   @default(now())

  @@index([userId])
  @@index([problemId])
  @@index([revisionDate])
  @@map("dsa_revision_logs")
}

model DsaPatternMastery {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern     String
  solvedCount Int      @default(0)
  totalCount  Int      @default(0)
  masteryPct  Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, pattern])
  @@index([userId])
  @@map("dsa_pattern_mastery")
}

model DsaTopicMastery {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       String
  solvedCount Int      @default(0)
  totalCount  Int      @default(0)
  masteryPct  Int      @default(0)
  weakScore   Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, topic])
  @@index([userId])
  @@map("dsa_topic_mastery")
}

model DsaPathProgress {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathId        String
  path          DsaPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  solvedCount   Int     @default(0)
  xpEarned      Int     @default(0)
  completionPct Int     @default(0)

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("dsa_path_progress")
}

model DsaUnlockedPath {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathId    String
  path      DsaPath  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([userId, pathId])
  @@index([userId])
  @@map("dsa_unlocked_paths")
}

model DsaHeatmap {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  count    Int      @default(0)
  xpEarned Int      @default(0)

  @@unique([userId, date])
  @@index([userId])
  @@map("dsa_heatmap")
}

model CompanyDsaMap {
  id       String   @id @default(cuid())
  company  String
  topics   String[] @default([])
  patterns String[] @default([])
  priority Int      @default(0)

  @@index([company])
  @@map("company_dsa_maps")
}

enum DsaStatus {
  TODO
  IN_PROGRESS
  SOLVED
  REVISING
}

// ==================== JOB TRACKER ====================

model JobApplication {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  role         String
  location     String?
  type         JobType   @default(FULL_TIME)
  status       JobStatus @default(SAVED)
  url          String?
  salary       String?
  notes        String?
  appliedDate  DateTime?
  deadline     DateTime?
  contactName  String?
  contactEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  source              String?
  requiredSkills      String[]  @default([])
  experience          String?
  workMode            String?
  description         String?
  companyInfo         String?
  interviewRounds     Json?
  matchScore          Int?
  recruiterNotes      String?
  interviewNotes      String?
  companyResearch     String?
  checklist           Json?
  personalNotes       String?
  aiPrepData          Json?
  aiPrepStatus        String    @default("idle")
  aiPrepLastGeneratedAt DateTime?
  prepStarted         Boolean   @default(false)
  prepStartedAt       DateTime?
  prepProgress        Int       @default(0)
  prepConfidence      Int       @default(0)
  prepDaysTotal       Int       @default(7)
  stageHistory        Json?

  @@index([userId])
  @@index([status])
  @@map("job_applications")
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
}

enum JobStatus {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

// ==================== PROJECT TRACKER ====================

model Project {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  priority    ProjectPriority @default(MEDIUM)
  techStack   String[]
  githubUrl   String?
  liveUrl     String?
  startDate   DateTime?     @db.Date
  endDate     DateTime?     @db.Date
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ==================== FINANCE TRACKER ====================

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  category    String
  description String?
  date        DateTime        @db.Date
  isRecurring Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@index([date])
  @@index([type])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ==================== FITNESS TRACKER ====================

model Workout {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String
  name           String
  duration       Int
  caloriesBurned Int?
  notes          String?
  exercises      Json     @default("[]")
  date           DateTime @db.Date
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([date])
  @@map("workouts")
}

model FitnessLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  weight    Float?
  steps     Int?
  water     Float?
  sleep     Float?
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@map("fitness_logs")
}
// ==================== FOCUS SESSIONS ====================

model FocusSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  duration    Int       // planned duration in minutes
  actualMins  Int?      // actual minutes completed
  label       String    @default("Deep Work Session")
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("focus_sessions")
}
